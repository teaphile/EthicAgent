  "rules": [
    {
      "id": "DRR001",
      "type": "hard_rule",
      "description": "Never prioritize rescue based on socioeconomic status or property value",
      "source": "FEMA / Civil Rights",
      "severity": "critical"
    },
    {
      "id": "DRR002",
      "type": "hard_rule",
      "description": "Never discriminate in evacuation assistance based on immigration status",
      "source": "Stafford Act",
      "severity": "critical"
    },
    {
      "id": "DRR003",
      "type": "hard_rule",
      "description": "Ensure accessible evacuation for disabled individuals",
      "source": "ADA",
      "severity": "critical"
    },
    {
      "id": "DRR004",
      "type": "soft_rule",
      "description": "Prioritize areas with highest population density and vulnerability",
      "source": "Emergency management doctrine",
      "severity": "high"
    },
    {
      "id": "DRR005",
      "type": "soft_rule",
      "description": "Use vulnerability indices rather than property values for resource allocation",
      "source": "Equity framework",
      "severity": "high"
    },
    {
      "id": "DRR006",
      "type": "hard_rule",
      "description": "Never withhold aid as punishment for non-compliance with evacuation orders",
      "source": "Humanitarian law",
      "severity": "critical"
    },
    {
      "id": "DRR007",
      "type": "soft_rule",
      "description": "Coordinate with community organizations for culturally appropriate response",
      "source": "FEMA whole-community approach",
      "severity": "medium"
    },
    {
      "id": "DRR008",
      "type": "soft_rule",
      "description": "Provide multilingual emergency communications",
      "source": "EO 13166",
      "severity": "high"
    },
    {
      "id": "DRR009",
      "type": "hard_rule",
      "description": "Never force separation of families during evacuation",
      "source": "Humanitarian principles",
      "severity": "high"
    },
    {
      "id": "DRR010",
      "type": "soft_rule",
      "description": "Document resource allocation decisions for post-event review",
      "source": "Accountability principle",
      "severity": "medium"
    },
    {
      "id": "DRR011",
      "type": "hard_rule",
      "description": "Never deny first aid to injured persons regardless of circumstances",
      "source": "Geneva Conventions / humanitarian law",
      "severity": "critical"
    }
  ],
