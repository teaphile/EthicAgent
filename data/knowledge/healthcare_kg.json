  "rules": [
    {
      "id": "HR001",
      "type": "hard_rule",
      "description": "Never withhold emergency life-saving treatment",
      "source": "Hippocratic Oath / EMTALA",
      "severity": "critical"
    },
    {
      "id": "HR002",
      "type": "hard_rule",
      "description": "Never discriminate based on disability status in treatment allocation",
      "source": "ADA Section 504",
      "severity": "critical"
    },
    {
      "id": "HR003",
      "type": "hard_rule",
      "description": "Always obtain informed consent before elective procedures",
      "source": "Medical Ethics Canon",
      "severity": "high"
    },
    {
      "id": "HR004",
      "type": "hard_rule",
      "description": "Never disclose patient information without authorization",
      "source": "HIPAA",
      "severity": "critical"
    },
    {
      "id": "HR005",
      "type": "hard_rule",
      "description": "Honor valid Do Not Resuscitate (DNR) orders",
      "source": "Patient Self-Determination Act",
      "severity": "high"
    },
    {
      "id": "HR006",
      "type": "soft_rule",
      "description": "Prioritize medical urgency over social value judgments",
      "source": "AMA Code of Ethics",
      "severity": "medium"
    },
    {
      "id": "HR007",
      "type": "soft_rule",
      "description": "Consider quality-adjusted life years (QALY) in resource allocation",
      "source": "Utilitarian ethics",
      "severity": "medium"
    },
    {
      "id": "HR008",
      "type": "soft_rule",
      "description": "Escalate to ethics committee when competing patient needs arise",
      "source": "Hospital Policy",
      "severity": "medium"
    },
    {
      "id": "HR009",
      "type": "hard_rule",
      "description": "Never allocate resources based on patient's ability to pay",
      "source": "EMTALA / Medical Ethics",
      "severity": "critical"
    },
    {
      "id": "HR010",
      "type": "soft_rule",
      "description": "Consider patient's expressed wishes and advance directives",
      "source": "Autonomy principle",
      "severity": "high"
    },
    {
      "id": "HR011",
      "type": "hard_rule",
      "description": "Never use race as a factor in clinical decision algorithms",
      "source": "Anti-discrimination law",
      "severity": "critical"
    },
    {
      "id": "HR012",
      "type": "soft_rule",
      "description": "Involve palliative care early for terminal diagnoses",
      "source": "WHO Guidelines",
      "severity": "medium"
    }
  ],
