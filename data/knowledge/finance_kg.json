  "rules": [
    {
      "id": "FR001",
      "type": "hard_rule",
      "description": "Never use race, ethnicity, or national origin in credit decisions",
      "source": "ECOA / Fair Housing Act",
      "severity": "critical"
    },
    {
      "id": "FR002",
      "type": "hard_rule",
      "description": "Never use religion or marital status in credit decisions",
      "source": "ECOA",
      "severity": "critical"
    },
    {
      "id": "FR003",
      "type": "hard_rule",
      "description": "Provide adverse action notice when denying credit",
      "source": "ECOA / FCRA",
      "severity": "high"
    },
    {
      "id": "FR004",
      "type": "hard_rule",
      "description": "Never engage in predatory lending practices",
      "source": "Dodd-Frank Act",
      "severity": "critical"
    },
    {
      "id": "FR005",
      "type": "soft_rule",
      "description": "Monitor models for disparate impact on protected groups",
      "source": "CFPB Guidelines",
      "severity": "high"
    },
    {
      "id": "FR006",
      "type": "soft_rule",
      "description": "Consider alternative data sources that improve inclusion",
      "source": "Industry best practice",
      "severity": "medium"
    },
    {
      "id": "FR007",
      "type": "hard_rule",
      "description": "Never use zip code as sole proxy for creditworthiness",
      "source": "Fair lending law",
      "severity": "high"
    },
    {
      "id": "FR008",
      "type": "soft_rule",
      "description": "Explain model decisions in plain language to applicants",
      "source": "TILA / transparency principle",
      "severity": "medium"
    },
    {
      "id": "FR009",
      "type": "hard_rule",
      "description": "Never charge higher rates based on gender or age alone",
      "source": "ECOA",
      "severity": "critical"
    },
    {
      "id": "FR010",
      "type": "soft_rule",
      "description": "Ensure APR is clearly disclosed before agreement",
      "source": "TILA",
      "severity": "high"
    },
    {
      "id": "FR011",
      "type": "hard_rule",
      "description": "Never deny insurance claims based on pre-existing conditions when prohibited",
      "source": "ACA",
      "severity": "critical"
    }
  ],
