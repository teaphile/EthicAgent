      "description": "Transparency builds trust"
    },
    {
      "from": "consent",
      "to": "autonomy",
      "type": "implements",
      "description": "Consent is the practical expression of autonomy"
    },
    {
      "from": "dignity",
      "to": "non_maleficence",
      "type": "supports",
      "description": "Respecting dignity requires avoiding harm"
    },
    {
      "from": "care",
      "to": "beneficence",
      "type": "motivates",
      "description": "Care ethic motivates beneficent action"
    },
    {
      "from": "utility",
      "to": "justice",
      "type": "may_conflict_with",
      "description": "Maximizing utility may produce unjust distributions"
    },
    {
      "from": "accountability",
      "to": "trust",
      "type": "builds",
      "description": "Being accountable builds institutional trust"
    },
    {
      "from": "fairness",
      "to": "equity",
      "type": "supports",
      "description": "Fairness considerations include equity concerns"
    },
    {
      "from": "proportionality",
      "to": "justice",
      "type": "constrains",
      "description": "Justice must be proportional to the situation"
    }
  ],
