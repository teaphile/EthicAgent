  "rules": [
    {
      "id": "HRR001",
      "type": "hard_rule",
      "description": "Never use race, gender, or ethnicity in hiring decisions",
      "source": "Title VII",
      "severity": "critical"
    },
    {
      "id": "HRR002",
      "type": "hard_rule",
      "description": "Never discriminate based on age for workers 40+",
      "source": "ADEA",
      "severity": "critical"
    },
    {
      "id": "HRR003",
      "type": "hard_rule",
      "description": "Provide reasonable accommodation for qualified disabled candidates",
      "source": "ADA",
      "severity": "high"
    },
    {
      "id": "HRR004",
      "type": "hard_rule",
      "description": "Never require genetic testing or use genetic information",
      "source": "GINA",
      "severity": "critical"
    },
    {
      "id": "HRR005",
      "type": "soft_rule",
      "description": "Use structured interviews with standardized questions",
      "source": "I/O Psychology best practice",
      "severity": "medium"
    },
    {
      "id": "HRR006",
      "type": "soft_rule",
      "description": "Blind resume screening to remove name/photo bias",
      "source": "DEI best practice",
      "severity": "medium"
    },
    {
      "id": "HRR007",
      "type": "hard_rule",
      "description": "Never penalize candidates for pregnancy or parental status",
      "source": "Pregnancy Discrimination Act",
      "severity": "critical"
    },
    {
      "id": "HRR008",
      "type": "soft_rule",
      "description": "Validate assessment tools for adverse impact",
      "source": "EEOC Uniform Guidelines",
      "severity": "high"
    },
    {
      "id": "HRR009",
      "type": "soft_rule",
      "description": "Document legitimate business reasons for hiring criteria",
      "source": "Legal best practice",
      "severity": "medium"
    },
    {
      "id": "HRR010",
      "type": "hard_rule",
      "description": "Never use employment gap as proxy for protected status",
      "source": "Anti-discrimination principle",
      "severity": "high"
    },
    {
      "id": "HRR011",
      "type": "soft_rule",
      "description": "Ensure diverse interview panels when possible",
      "source": "DEI best practice",
      "severity": "medium"
    }
  ],
